APP_NAME=AI Recruitment System
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql+psycopg://ai_recruitment:ai_recruitment@postgres:5432/ai_recruitment
REDIS_URL=redis://redis:6379/0
UPLOAD_DIR=/app/uploads
STORAGE_BACKEND=minio
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=resumes
MINIO_SECURE=false
LLM_PROVIDER=mock
LLM_MODEL=mock-recruitment
