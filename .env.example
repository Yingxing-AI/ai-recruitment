APP_NAME=AI Recruitment System
ENVIRONMENT=development
SECRET_KEY=change-me-in-production

POSTGRES_DB=ai_recruitment
POSTGRES_USER=ai_recruitment
POSTGRES_PASSWORD=ai_recruitment
DATABASE_URL=postgresql+psycopg://ai_recruitment:ai_recruitment@postgres:5432/ai_recruitment

REDIS_URL=redis://redis:6379/0

BACKEND_CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=/app/uploads
STORAGE_BACKEND=minio

LLM_PROVIDER=mock
LLM_MODEL=mock-recruitment
LLM_API_KEY=
LLM_BASE_URL=

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_BUCKET=resumes
MINIO_SECURE=false

VITE_API_BASE_URL=http://localhost:8000/api/v1

# 中国大陆网络启动建议：
# 默认通过 DOCKER_IMAGE_PROXY 代理 Docker Hub 官方镜像。
# 如果 docker.1ms.run 在你的网络不可用，可改成公司内网镜像仓库，或尝试：
# DOCKER_IMAGE_PROXY=docker.1panel.live
# DOCKER_IMAGE_PROXY=docker.m.daocloud.io
DOCKER_IMAGE_PROXY=docker.1ms.run
PYTHON_BASE_IMAGE=docker.1ms.run/python:3.11-slim
NODE_BASE_IMAGE=docker.1ms.run/node:20-alpine
NGINX_BASE_IMAGE=docker.1ms.run/nginx:1.27-alpine
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com
